# ============================================================
# Monarch Money MCP Server - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to Git!
# ============================================================

# --- Monarch Money Credentials ---
# Used only by login_setup.py for the one-time auth setup.
# After running login_setup.py, a session token is saved and
# these variables are no longer required at runtime.
MONARCH_EMAIL=your_email@example.com
MONARCH_PASSWORD=your_password_here

# --- Cloud Deployment (Render, etc.) ---
# Set MONARCH_TOKEN to the auth token obtained after running
# login_setup.py locally. This bypasses keyring on servers.
# MONARCH_TOKEN=your_monarch_token_here

# Transport mode: "stdio" for local/Claude Desktop, "sse" for Render
# MCP_TRANSPORT=stdio

# Server binding (only used when MCP_TRANSPORT=sse)
# HOST=0.0.0.0
# PORT=8000

# --- Debug / Logging ---
# Set to DEBUG for verbose output, INFO for normal, WARNING for quiet
LOG_LEVEL=INFO
